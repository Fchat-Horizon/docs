{
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "vueIndentScriptAndStyle": true,
  "singleAttributePerLine": false,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": "**/*.vue",
      "options": {
        "singleAttributePerLine": true
      }
    }
  ]
}
